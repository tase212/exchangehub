generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  passwordHash  String    @map("password_hash")
  phone         String?
  avatar        String?
  kycStatus     String    @default("PENDING") @map("kyc_status")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  wallets          Wallet[]
  sellOrders       Order[]       @relation("Seller")
  buyOrders        Order[]       @relation("Buyer")
  reviewsGiven     Review[]      @relation("Reviewer")
  reviewsTaken     Review[]      @relation("Target")
  rateAlerts       RateAlert[]
  kycSubmissions   KycSubmission[]
  bankCards        BankCard[]
  bankAccounts     BankAccount[]
  transactions     Transaction[]

  @@map("users")
}

model Wallet {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  currency      String
  balance       Float    @default(0)
  frozenBalance Float    @default(0) @map("frozen_balance")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, currency])
  @@map("wallets")
}

model Order {
  id            String      @id @default(uuid())
  sellerId      String      @map("seller_id")
  buyerId       String?     @map("buyer_id")
  
  sellCurrency  String      @map("sell_currency")
  sellAmount    Float       @map("sell_amount")
  buyCurrency   String      @map("buy_currency")
  buyAmount     Float       @map("buy_amount")
  
  rate          Float
  status        String      @default("OPEN")
  
  method        String
  location      String?
  note          String?
  
  frozenWalletId String?    @map("frozen_wallet_id")
  
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  completedAt   DateTime?   @map("completed_at")

  seller        User        @relation("Seller", fields: [sellerId], references: [id])
  buyer         User?       @relation("Buyer", fields: [buyerId], references: [id])
  reviews       Review[]
  commissions   Commission[]

  @@index([sellCurrency, buyCurrency, status])
  @@index([sellerId])
  @@index([buyerId])
  @@map("orders")
}

model Review {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  reviewerId String  @map("reviewer_id")
  targetId  String   @map("target_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")

  order     Order    @relation(fields: [orderId], references: [id])
  reviewer  User     @relation("Reviewer", fields: [reviewerId], references: [id])
  target    User     @relation("Target", fields: [targetId], references: [id])

  @@unique([orderId, reviewerId])
  @@map("reviews")
}

model ExchangeShop {
  id            String   @id @default(uuid())
  name          String
  address       String
  city          String
  country       String
  phone         String?
  lat           Float?
  lng           Float?
  currencies    String
  rating        Float    @default(0)
  reviewCount   Int      @default(0) @map("review_count")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([city, country])
  @@map("exchange_shops")
}

model RateAlert {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  fromCurrency String  @map("from_currency")
  toCurrency  String   @map("to_currency")
  targetRate  Float    @map("target_rate")
  isAbove     Boolean  @default(true) @map("is_above")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rate_alerts")
}

model KycSubmission {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  idType        String   @map("id_type")
  idFrontImage  String   @map("id_front_image")
  idBackImage   String?  @map("id_back_image")
  selfieImage   String   @map("selfie_image")
  status        String   @default("SUBMITTED")
  rejectReason  String?  @map("reject_reason")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kyc_submissions")
}

model BankCard {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  cardLast4     String   @map("card_last4")
  cardholder    String
  expiryMonth   Int      @map("expiry_month")
  expiryYear    Int      @map("expiry_year")
  brand         String
  bankName      String?  @map("bank_name")
  isDefault     Boolean  @default(false) @map("is_default")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bank_cards")
}

model BankAccount {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  accountLast4  String   @map("account_last4")
  routingCode   String?  @map("routing_code")
  bankName      String   @map("bank_name")
  accountHolder String   @map("account_holder")
  country       String
  currency      String
  isDefault     Boolean  @default(false) @map("is_default")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bank_accounts")
}

model Transaction {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  type            String
  amount          Float
  currency        String
  fee             Float    @default(0)
  status          String   @default("PENDING")
  referenceNo     String   @unique @map("reference_no")
  paymentMethod   String?  @map("payment_method")
  relatedCardId   String?  @map("related_card_id")
  relatedAccountId String? @map("related_account_id")
  relatedOrderId  String?  @map("related_order_id")
  note            String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  completedAt     DateTime? @map("completed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([userId, status])
  @@map("transactions")
}

model Admin {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  name          String
  role          String   @default("ADMIN")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  commissions   Commission[]
  withdrawals   AdminWithdrawal[]

  @@map("admins")
}

model Commission {
  id            String   @id @default(uuid())
  orderId       String   @map("order_id")
  adminId       String?  @map("admin_id")
  orderAmount   Float    @map("order_amount")
  rate          Float
  amount        Float
  currency      String
  status        String   @default("PENDING")
  createdAt     DateTime @default(now()) @map("created_at")

  order         Order?   @relation(fields: [orderId], references: [id])
  admin         Admin?   @relation(fields: [adminId], references: [id])

  @@index([status])
  @@map("commissions")
}

model AdminWithdrawal {
  id            String   @id @default(uuid())
  adminId       String?  @map("admin_id")
  amount        Float
  currency      String
  bankName      String   @map("bank_name")
  accountLast4  String   @map("account_last4")
  accountHolder String   @map("account_holder")
  status        String   @default("PENDING")
  note          String?
  createdAt     DateTime @default(now()) @map("created_at")
  completedAt   DateTime? @map("completed_at")

  admin         Admin?   @relation(fields: [adminId], references: [id])

  @@map("admin_withdrawals")
}

# 本地 PostgreSQL（Docker 或本地安装）
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/exchangehub?schema=public"

# JWT 密钥 - 生成: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# 部署后改为实际域名
NEXTAUTH_URL="http://localhost:3000"

# 免费汇率API（可选，不配置则使用内置汇率）
EXCHANGE_RATE_API_KEY="demo"
